{
  "name": "yomi-calendar-share",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "worker:check": "tsc -p tsconfig.worker.json",
    "cf:dev": "npm run build && wrangler dev",
    "cf:deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply yomi-calendar-share-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply yomi-calendar-share-db --remote"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260529.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "wrangler": "^4.95.0"
  }
}
